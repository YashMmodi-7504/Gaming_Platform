// =============================================================================
// Game Sessions, Statistics, Leaderboards, Achievements & Rewards
// =============================================================================

model GameSession {
  id           String            @id @default(uuid(7)) @db.Uuid
  userId       String            @map("user_id") @db.Uuid
  gameId       String            @map("game_id") @db.Uuid
  currencyId   String            @map("currency_id") @db.Uuid
  status       GameSessionStatus @default(ACTIVE)
  mode         String            @default("real")
  externalRef  String?           @map("external_ref")
  totalBet     Decimal           @default(0) @map("total_bet") @db.Decimal(38, 18)
  totalWin     Decimal           @default(0) @map("total_win") @db.Decimal(38, 18)
  roundsPlayed Int               @default(0) @map("rounds_played")
  startedAt    DateTime          @default(now()) @map("started_at")
  endedAt      DateTime?         @map("ended_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user           User              @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  game           Game              @relation(fields: [gameId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  currency       Currency          @relation(fields: [currencyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  playerSessions PlayerSession[]
  results        GameResult[]
  runtimeState   GameRuntimeState?
  replays        GameReplay[]

  @@index([userId, createdAt])
  @@index([gameId, createdAt])
  @@index([status])
  @@map("game_sessions")
}

model PlayerSession {
  id        String    @id @default(uuid(7)) @db.Uuid
  sessionId String    @map("session_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  seat      Int?
  status    String    @default("active")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  createdAt DateTime @default(now()) @map("created_at")

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([sessionId, userId])
  @@index([userId])
  @@map("player_sessions")
}

model GameResult {
  id         String      @id @default(uuid(7)) @db.Uuid
  sessionId  String      @map("session_id") @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  gameId     String      @map("game_id") @db.Uuid
  roundId    String?     @map("round_id")
  outcome    GameOutcome @default(PENDING)
  betAmount  Decimal     @default(0) @map("bet_amount") @db.Decimal(38, 18)
  winAmount  Decimal     @default(0) @map("win_amount") @db.Decimal(38, 18)
  multiplier Decimal?    @db.Decimal(18, 6)
  payload    Json?       @db.JsonB
  playedAt   DateTime    @default(now()) @map("played_at")

  createdAt DateTime @default(now()) @map("created_at")

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  game    Game        @relation(fields: [gameId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([sessionId])
  @@index([userId, playedAt])
  @@index([gameId, playedAt])
  @@index([outcome])
  @@map("game_results")
}

model PlayerStatistics {
  id           String    @id @default(uuid(7)) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  gameId       String?   @map("game_id") @db.Uuid
  totalRounds  Int       @default(0) @map("total_rounds")
  totalWagered Decimal   @default(0) @map("total_wagered") @db.Decimal(38, 18)
  totalWon     Decimal   @default(0) @map("total_won") @db.Decimal(38, 18)
  biggestWin   Decimal   @default(0) @map("biggest_win") @db.Decimal(38, 18)
  winCount     Int       @default(0) @map("win_count")
  lossCount    Int       @default(0) @map("loss_count")
  lastPlayedAt DateTime? @map("last_played_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  game Game? @relation(fields: [gameId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
  @@map("player_statistics")
}

model GameStatistics {
  id               String    @id @default(uuid(7)) @db.Uuid
  gameId           String    @unique @map("game_id") @db.Uuid
  totalRounds      BigInt    @default(0) @map("total_rounds")
  totalWagered     Decimal   @default(0) @map("total_wagered") @db.Decimal(38, 18)
  totalPaidOut     Decimal   @default(0) @map("total_paid_out") @db.Decimal(38, 18)
  uniquePlayers    Int       @default(0) @map("unique_players")
  lastCalculatedAt DateTime? @map("last_calculated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("game_statistics")
}

model Leaderboard {
  id       String            @id @default(uuid(7)) @db.Uuid
  gameId   String?           @map("game_id") @db.Uuid
  name     String
  metric   String            @default("score")
  period   LeaderboardPeriod @default(ALL_TIME)
  startsAt DateTime?         @map("starts_at")
  endsAt   DateTime?         @map("ends_at")
  isActive Boolean           @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  game    Game?              @relation(fields: [gameId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  entries LeaderboardEntry[]

  @@index([gameId])
  @@index([period, isActive])
  @@map("leaderboards")
}

model LeaderboardEntry {
  id            String  @id @default(uuid(7)) @db.Uuid
  leaderboardId String  @map("leaderboard_id") @db.Uuid
  userId        String  @map("user_id") @db.Uuid
  rank          Int
  score         Decimal @default(0) @db.Decimal(38, 8)
  metadata      Json?   @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leaderboard Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([leaderboardId, userId])
  @@index([leaderboardId, rank])
  @@index([userId])
  @@map("leaderboard_entries")
}

model Achievement {
  id          String          @id @default(uuid(7)) @db.Uuid
  slug        String          @unique
  name        String
  description String?
  type        AchievementType @default(MILESTONE)
  iconUrl     String?         @map("icon_url")
  points      Int             @default(0)
  criteria    Json?           @db.JsonB
  isActive    Boolean         @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  userAchievements UserAchievement[]

  @@index([type, isActive])
  @@map("achievements")
}

model UserAchievement {
  id            String    @id @default(uuid(7)) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  achievementId String    @map("achievement_id") @db.Uuid
  progress      Int       @default(0)
  isUnlocked    Boolean   @default(false) @map("is_unlocked")
  unlockedAt    DateTime? @map("unlocked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, isUnlocked])
  @@map("user_achievements")
}

model Reward {
  id           String     @id @default(uuid(7)) @db.Uuid
  slug         String     @unique
  name         String
  type         RewardType @default(BONUS)
  value        Decimal?   @db.Decimal(38, 18)
  currencyCode String?    @map("currency_code")
  description  String?
  isActive     Boolean    @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  claims RewardClaim[]

  @@index([type, isActive])
  @@map("rewards")
}

model RewardClaim {
  id        String            @id @default(uuid(7)) @db.Uuid
  userId    String            @map("user_id") @db.Uuid
  rewardId  String            @map("reward_id") @db.Uuid
  status    RewardClaimStatus @default(PENDING)
  claimedAt DateTime?         @map("claimed_at")
  expiresAt DateTime?         @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, status])
  @@index([rewardId])
  @@map("reward_claims")
}

{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "strictPropertyInitialization": false,
    "noImplicitAny": true,
    // NestJS relies on dependency injection where providers are frequently
    // injected for availability rather than direct use in a method body.
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "declaration": true,
    "removeComments": true,
    "allowJs": false,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./"
  }
}

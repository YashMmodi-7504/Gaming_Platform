# Staging overrides — loaded after .env when NODE_ENV=staging.
# Real secrets are injected by the deployment platform, never committed.
NODE_ENV=staging
LOG_LEVEL=info
SWAGGER_ENABLED=true
AUTH_COOKIE_SECURE=true
CORS_ORIGINS=https://staging.example.com
NEXT_PUBLIC_ENVIRONMENT=staging
RATE_LIMIT_LIMIT=120

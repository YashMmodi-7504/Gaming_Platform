{
  "name": "gaming-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise gaming platform monorepo — production-grade foundation",
  "author": "LogicRest AI",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "db:generate": "turbo run db:generate",
    "prisma:generate": "turbo run db:generate",
    "db:migrate": "pnpm --filter @gaming-platform/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @gaming-platform/database db:migrate:deploy",
    "db:push": "pnpm --filter @gaming-platform/database db:push",
    "db:studio": "pnpm --filter @gaming-platform/database db:studio",
    "db:seed": "pnpm --filter @gaming-platform/database db:seed",
    "prepare": "husky",
    "docker:up": "docker compose -f docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "rimraf": "^6.0.1",
    "turbo": "^2.10.2",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}

# =============================================================================
# Gaming Platform — Environment Variables (EXAMPLE)
# -----------------------------------------------------------------------------
# Copy this file to `.env` for local development:
#     cp .env.example .env
#
# Environment-specific overrides live in:
#     .env.development   .env.staging   .env.production
# Never commit real secrets. This file documents every supported variable.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=gaming-platform
TZ=UTC

# -----------------------------------------------------------------------------
# Backend (NestJS)
# -----------------------------------------------------------------------------
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0
API_PREFIX=api
API_VERSION=1
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:4000
# Global request rate limiting (requests per TTL window)
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=120
# Swagger docs
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
# Logging: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
# Public variables are exposed to the browser — prefix with NEXT_PUBLIC_
NEXT_PUBLIC_APP_NAME=Gaming Platform
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=gaming
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=gaming_platform
# Full connection string used by Prisma (host=postgres inside docker network)
DATABASE_URL=postgresql://gaming:change_me_in_production@postgres:5432/gaming_platform?schema=public
# For running Prisma from the host machine, use localhost:
# DATABASE_URL=postgresql://gaming:change_me_in_production@localhost:5432/gaming_platform?schema=public

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379
REDIS_TTL=3600

# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------
# Generate strong secrets, e.g.: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
# Cookie used to store the refresh token
AUTH_COOKIE_NAME=gp_refresh
AUTH_COOKIE_DOMAIN=localhost
AUTH_COOKIE_SECURE=false
REMEMBER_ME_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Security policy
# -----------------------------------------------------------------------------
ACCOUNT_LOCK_MAX_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15
MAX_CONCURRENT_SESSIONS=5
# Check new passwords against the HaveIBeenPwned k-anonymity API
PASSWORD_BREACH_CHECK_ENABLED=false
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30
TWO_FACTOR_ISSUER=Gaming Platform
# Public web URL used to build links in transactional emails
APP_WEB_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Mailer (SMTP) — when MAIL_HOST is empty, emails are logged instead of sent
# -----------------------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=Gaming Platform <no-reply@gaming-platform.local>

# -----------------------------------------------------------------------------
# Observability / Misc
# -----------------------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# -----------------------------------------------------------------------------
# Nginx (reverse proxy)
# -----------------------------------------------------------------------------
NGINX_PORT=80
NGINX_SSL_PORT=443

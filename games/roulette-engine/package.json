    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@gaming-platform/game-sdk": "workspace:*"
  },
  "devDependencies": {
    "@gaming-platform/config": "workspace:*",
    "eslint": "^10.7.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
